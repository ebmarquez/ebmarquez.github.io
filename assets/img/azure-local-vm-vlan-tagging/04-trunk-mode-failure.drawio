  <diagram id="trunk-mode-failure" name="Trunk Mode Failure Path">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;Trunk Mode: Why Return Traffic Fails on Azure Local&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="800" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="&lt;font color=&quot;#cc0000&quot;&gt;❌ SR-IOV and NetIntent do NOT handle this correctly&lt;/font&gt;" style="text;html=1;align=center;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="450" y="55" width="500" height="30" as="geometry"/>
        </mxCell>

        <!-- ===== OUTBOUND PATH ===== -->
        <mxCell id="out-label" value="&lt;b&gt;OUTBOUND: VM → Network (works ✅)&lt;/b&gt;" style="text;html=1;align=left;fontSize=14;fontColor=#006600;" vertex="1" parent="1">
          <mxGeometry x="50" y="100" width="400" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="out-vm" value="&lt;b&gt;VM&lt;/b&gt;&lt;br&gt;eth0.4&lt;br&gt;&lt;font face=&quot;Consolas&quot; size=&quot;1&quot;&gt;-Trunk -NativeVlanId 1&lt;br&gt;-AllowedVlanIdList '4'&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="50" y="145" width="170" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="out-frame1" value="&lt;font face=&quot;Consolas&quot;&gt;Dst | Src | &lt;b&gt;VLAN4&lt;/b&gt; | Payload&lt;/font&gt;&lt;br&gt;&lt;i&gt;VM adds 802.1Q tag itself&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="255" y="155" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="out-arrow1" value="" style="endArrow=block;endFill=1;strokeColor=#d6b656;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="465" y="175" as="sourcePoint"/>
            <mxPoint x="520" y="175" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="out-vs" value="&lt;b&gt;vSwitch&lt;/b&gt;&lt;br&gt;Passes tagged&lt;br&gt;frame through" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="520" y="150" width="150" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="out-arrow2" value="" style="endArrow=block;endFill=1;strokeColor=#9673a6;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="680" y="175" as="sourcePoint"/>
            <mxPoint x="740" y="175" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="out-nic" value="&lt;b&gt;Physical NIC&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="740" y="150" width="120" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="out-arrow3" value="" style="endArrow=block;endFill=1;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="870" y="175" as="sourcePoint"/>
            <mxPoint x="930" y="175" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="out-tor" value="&lt;b&gt;ToR Switch&lt;/b&gt;&lt;br&gt;Trunk Port&lt;br&gt;Accepts VLAN 4" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="930" y="150" width="140" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="out-arp" value="&lt;b&gt;ARP Request&lt;/b&gt;&lt;br&gt;arrives at Host-2 ✅" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1110" y="150" width="150" height="65" as="geometry"/>
        </mxCell>

        <!-- Divider -->
        <mxCell id="divider" value="" style="endArrow=none;dashed=1;strokeColor=#cccccc;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="50" y="270" as="sourcePoint"/>
            <mxPoint x="1380" y="270" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- ===== RETURN PATH (FAILS) ===== -->
        <mxCell id="ret-label" value="&lt;b&gt;RETURN: Network → VM (FAILS ❌)&lt;/b&gt;" style="text;html=1;align=left;fontSize=14;fontColor=#cc0000;" vertex="1" parent="1">
          <mxGeometry x="50" y="290" width="400" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="ret-arp" value="&lt;b&gt;ARP Reply&lt;/b&gt;&lt;br&gt;generated on Host-2 ✅" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="50" y="340" width="150" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="ret-arrow1" value="" style="endArrow=block;endFill=1;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="210" y="370" as="sourcePoint"/>
            <mxPoint x="270" y="370" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="ret-tor" value="&lt;b&gt;ToR Switch&lt;/b&gt;&lt;br&gt;Forwards VLAN 4&lt;br&gt;tagged reply" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="270" y="340" width="140" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="ret-arrow2" value="" style="endArrow=block;endFill=1;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="420" y="370" as="sourcePoint"/>
            <mxPoint x="480" y="370" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="ret-nic" value="&lt;b&gt;Physical NIC&lt;/b&gt;&lt;br&gt;Host-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="480" y="340" width="120" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="ret-arrow3" value="" style="endArrow=block;endFill=1;strokeColor=#b85450;strokeWidth=3;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="610" y="370" as="sourcePoint"/>
            <mxPoint x="680" y="370" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- FAILURE POINT -->
        <mxCell id="ret-vs" value="&lt;b&gt;vSwitch&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#cc0000&quot;&gt;❌ DROPS&lt;br&gt;RETURN TRAFFIC&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="680" y="330" width="180" height="85" as="geometry"/>
        </mxCell>
        <mxCell id="ret-arrow4" value="" style="endArrow=block;endFill=1;strokeColor=#cccccc;strokeWidth=2;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="870" y="370" as="sourcePoint"/>
            <mxPoint x="940" y="370" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="ret-vm" value="&lt;b&gt;VM&lt;/b&gt;&lt;br&gt;eth0.4&lt;br&gt;&lt;font color=&quot;#cc0000&quot;&gt;Never receives reply&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#cccccc;fontSize=12;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="940" y="340" width="170" height="65" as="geometry"/>
        </mxCell>

        <!-- Callout boxes -->
        <mxCell id="callout1" value="&lt;b&gt;Why it drops:&lt;/b&gt;&lt;br&gt;SR-IOV hardware offload does not expect&lt;br&gt;VM-tagged frames on the return path.&lt;br&gt;The offload path is optimized for the&lt;br&gt;vSwitch to manage all VLAN tagging." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="100" y="470" width="350" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="callout2" value="&lt;b&gt;NetIntent conflict:&lt;/b&gt;&lt;br&gt;NetIntent manages the vSwitch and sets&lt;br&gt;VLAN filtering rules. VM-initiated tags&lt;br&gt;are outside NetIntent's scope and may&lt;br&gt;not be included in the filter tables." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="500" y="470" width="350" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="callout3" value="&lt;b&gt;The evidence:&lt;/b&gt;&lt;br&gt;• ARP requests reach the remote host ✅&lt;br&gt;• ARP replies are generated ✅&lt;br&gt;• ARP replies never arrive back ❌&lt;br&gt;• Classic unidirectional return-path failure" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="900" y="470" width="350" height="90" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
