        <mxCell id="ret-nic" value="&lt;b&gt;Physical NIC&lt;/b&gt;&lt;br&gt;← Wire" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="280" y="350" width="130" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="ret-frame1" value="&lt;font face=&quot;Consolas&quot;&gt;Dst | Src | &lt;b&gt;VLAN4&lt;/b&gt; | Payload&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
