  <diagram id="access-mode-flow" name="Access Mode Flow — Success Path">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;Access Mode: How Traffic Flows (Both Directions)&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="800" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="&lt;font color=&quot;#009900&quot;&gt;✅ SR-IOV and NetIntent handle this correctly&lt;/font&gt;" style="text;html=1;align=center;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="450" y="55" width="500" height="30" as="geometry"/>
        </mxCell>

        <!-- ===== OUTBOUND PATH (Top) ===== -->
