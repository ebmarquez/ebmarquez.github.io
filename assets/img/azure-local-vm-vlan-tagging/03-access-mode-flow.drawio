          <mxGeometry x="50" y="300" width="300" height="30" as="geometry"/>
        </mxCell>

        <!-- ToR -->
        <mxCell id="ret-tor" value="&lt;b&gt;ToR Switch&lt;/b&gt;&lt;br&gt;Sends VLAN 4&lt;br&gt;tagged frame" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="50" y="350" width="150" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="ret-arrow1" value="" style="endArrow=block;endFill=1;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" parent="1">
