          <mxGeometry x="500" y="150" width="160" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="out-frame2" value="&lt;font face=&quot;Consolas&quot;&gt;Dst | Src | &lt;b&gt;VLAN4&lt;/b&gt; | Payload&lt;/font&gt;&lt;br&gt;&lt;i&gt;802.1Q tagged&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="700" y="155" width="200" height="40" as="geometry"/>
