            <mxPoint x="1110" y="175" as="sourcePoint"/>
            <mxPoint x="1170" y="175" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- ToR -->
        <mxCell id="out-tor" value="&lt;b&gt;ToR Switch&lt;/b&gt;&lt;br&gt;Trunk Port&lt;br&gt;VLAN 4 ✅" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1170" y="150" width="150" height="70" as="geometry"/>
