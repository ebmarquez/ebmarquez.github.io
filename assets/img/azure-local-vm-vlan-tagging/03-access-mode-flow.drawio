            <mxPoint x="720" y="385" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- vSwitch -->
        <mxCell id="ret-vs" value="&lt;b&gt;vSwitch&lt;/b&gt;&lt;br&gt;Strips VLAN 4&lt;br&gt;tag" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="720" y="350" width="160" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="ret-frame2" value="&lt;font face=&quot;Consolas&quot;&gt;Dst | Src | Payload&lt;/font&gt;&lt;br&gt;&lt;i&gt;Tag stripped&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#999999;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="920" y="360" width="180" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="ret-arrow3" value="" style="endArrow=block;endFill=1;strokeColor=#d6b656;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1110" y="385" as="sourcePoint"/>
            <mxPoint x="1170" y="385" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- VM -->
        <mxCell id="ret-vm" value="&lt;b&gt;VM&lt;/b&gt;&lt;br&gt;eth0&lt;br&gt;Receives clean frame" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1170" y="350" width="160" height="70" as="geometry"/>
