        </mxCell>
        <mxCell id="out-frame1" value="&lt;font face=&quot;Consolas&quot;&gt;Dst | Src | Payload&lt;/font&gt;&lt;br&gt;&lt;i&gt;No VLAN tag&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#999999;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="250" y="155" width="180" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="out-arrow1" value="" style="endArrow=block;endFill=1;strokeColor=#d6b656;strokeWidth=2;" edge="1" parent="1">
