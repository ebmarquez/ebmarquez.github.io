        <mxCell id="ret-check" value="✅" style="text;html=1;align=center;fontSize=24;" vertex="1" parent="1">
          <mxGeometry x="1330" y="360" width="50" height="50" as="geometry"/>
        </mxCell>

        <!-- Bottom note -->
        <mxCell id="note" value="&lt;b&gt;Why this works:&lt;/b&gt; The vSwitch manages all VLAN tagging. SR-IOV hardware offload understands this path.&lt;br&gt;NetIntent VLAN filtering rules correctly include vSwitch-managed tags. Both directions flow cleanly." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="200" y="480" width="1000" height="50" as="geometry"/>
        </mxCell>
      </root>
