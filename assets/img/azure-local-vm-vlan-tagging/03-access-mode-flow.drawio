        </mxCell>

        <!-- Physical NIC -->
        <mxCell id="out-nic" value="&lt;b&gt;Physical NIC&lt;/b&gt;&lt;br&gt;→ Wire" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="970" y="150" width="130" height="70" as="geometry"/>
