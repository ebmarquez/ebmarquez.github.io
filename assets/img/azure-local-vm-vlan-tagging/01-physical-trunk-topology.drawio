<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="draw.io" modified="2026-03-07" agent="Copilot" version="29.5.2">
  <diagram id="physical-trunk-topology" name="Physical Trunk Topology">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;Azure Local Physical Trunk Topology&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="450" y="20" width="500" height="40" as="geometry"/>
        </mxCell>
        <!-- Core Switch -->
        <mxCell id="core" value="&lt;b&gt;Core / Aggregation&lt;/b&gt;&lt;br&gt;L3 Gateway" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="550" y="80" width="300" height="60" as="geometry"/>
        </mxCell>
        <!-- ToR Switch 1 — far left -->
        <mxCell id="tor1" value="&lt;b&gt;ToR Switch 1&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="150" y="250" width="200" height="50" as="geometry"/>
        </mxCell>
        <!-- ToR Switch 2 — far right -->
        <mxCell id="tor2" value="&lt;b&gt;ToR Switch 2&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="1050" y="250" width="200" height="50" as="geometry"/>
        </mxCell>
        <!-- Host 1 — center-left -->
        <mxCell id="host1" value="&lt;b&gt;Host 1&lt;/b&gt;&lt;br&gt;Azure Local Node" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="370" y="470" width="220" height="60" as="geometry"/>
        </mxCell>
        <!-- Host 2 — center-right -->
        <mxCell id="host2" value="&lt;b&gt;Host 2&lt;/b&gt;&lt;br&gt;Azure Local Node" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="810" y="470" width="220" height="60" as="geometry"/>
        </mxCell>
        <!-- Core to ToR1 uplink -->
        <mxCell id="core-tor1" style="rounded=0;strokeColor=#82b366;strokeWidth=3;endArrow=none;" edge="1" parent="1" source="core" target="tor1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Core to ToR2 uplink -->
        <mxCell id="core-tor2" style="rounded=0;strokeColor=#82b366;strokeWidth=3;endArrow=none;" edge="1" parent="1" source="core" target="tor2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- ToR1 to Host1 (primary — solid) -->
        <mxCell id="tor1-host1" style="rounded=0;strokeColor=#6c8ebf;strokeWidth=2;endArrow=none;" edge="1" parent="1" source="tor1" target="host1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- ToR2 to Host2 (primary — solid) -->
        <mxCell id="tor2-host2" style="rounded=0;strokeColor=#6c8ebf;strokeWidth=2;endArrow=none;" edge="1" parent="1" source="tor2" target="host2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- ToR2 to Host1 (cross-connect — dashed) -->
        <mxCell id="tor2-host1" style="rounded=0;strokeColor=#6c8ebf;strokeWidth=2;dashed=1;endArrow=none;" edge="1" parent="1" source="tor2" target="host1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- ToR1 to Host2 (cross-connect — dashed) -->
        <mxCell id="tor1-host2" style="rounded=0;strokeColor=#6c8ebf;strokeWidth=2;dashed=1;endArrow=none;" edge="1" parent="1" source="tor1" target="host2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Dual-homed note -->
        <mxCell id="dh-note" value="&lt;i&gt;Each host is dual-homed to both ToRs (no LACP). All host-facing ports are trunks.&lt;/i&gt;" style="text;html=1;align=center;fontSize=11;fontColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="370" y="545" width="660" height="25" as="geometry"/>
        </mxCell>
        <!-- Legend box -->
        <mxCell id="legend-box" value="" style="rounded=1;whiteSpace=wrap;fillColor=#f9f9f9;strokeColor=#cccccc;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="620" width="380" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="legend-title" value="&lt;b&gt;Host-Facing Trunk Port Config&lt;/b&gt;" style="text;html=1;align=left;fontSize=12;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="70" y="630" width="300" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="legend-config" value="switchport mode trunk&lt;br&gt;native VLAN 2 (management)&lt;br&gt;allowed VLANs: 2, 4, 10, 20&lt;br&gt;MTU 9216" style="text;html=1;align=left;fontSize=11;fontColor=#555555;fontFamily=Consolas;" vertex="1" parent="1">
          <mxGeometry x="70" y="660" width="340" height="70" as="geometry"/>
        </mxCell>
        <!-- Legend lines -->
        <mxCell id="leg-line1" style="endArrow=none;strokeColor=#82b366;strokeWidth=3;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="70" y="750" as="sourcePoint"/>
            <mxPoint x="140" y="750" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="leg-label1" value="Uplink (Port-Channel)" style="text;html=1;align=left;fontSize=11;fontColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="150" y="740" width="200" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg-line2" style="endArrow=none;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="70" y="780" as="sourcePoint"/>
            <mxPoint x="140" y="780" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="leg-label2" value="Host Link (primary)" style="text;html=1;align=left;fontSize=11;fontColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="150" y="770" width="200" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg-line3" style="endArrow=none;strokeColor=#6c8ebf;strokeWidth=2;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="70" y="810" as="sourcePoint"/>
            <mxPoint x="140" y="810" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="leg-label3" value="Host Link (cross-connect)" style="text;html=1;align=left;fontSize=11;fontColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="150" y="800" width="250" height="20" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
