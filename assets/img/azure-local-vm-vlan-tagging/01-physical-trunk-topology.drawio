        </mxCell>
        <mxCell id="legend-host" value="Host Link (Individual Trunk)" style="text;html=1;align=left;fontSize=11;fontColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="80" y="655" width="250" height="25" as="geometry"/>
        </mxCell>
        <!-- Host1 label -->
        <mxCell id="host1-label" value="Port 0 → ToR1&lt;br&gt;Port 1 → ToR2&lt;br&gt;&lt;i&gt;Dual-homed, no LACP&lt;/i&gt;" style="text;html=1;align=center;fontSize=10;fontColor=#999999;" vertex="1" parent="1">
