          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- ToR2 to Host2 (port 1) -->
        <mxCell id="tor2-host2" value="Port 2 — Trunk" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6c8ebf;strokeWidth=2;fontSize=10;fontColor=#6c8ebf;" edge="1" parent="1" source="tor2" target="host2">
          <mxGeometry relative="1" as="geometry"/>
