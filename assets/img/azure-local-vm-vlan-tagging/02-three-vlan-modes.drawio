<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="draw.io" modified="2026-03-06" agent="Copilot" version="29.5.2">
  <diagram id="three-vlan-modes" name="Three VLAN Modes Comparison">
    <mxGraphModel dx="1400" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;Hyper-V VLAN Modes: How Each One Tags Traffic&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="900" height="40" as="geometry"/>
        </mxCell>

        <!-- ===== COLUMN 1: UNTAGGED ===== -->
        <mxCell id="col1-header" value="&lt;b&gt;Mode 1: Untagged&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;(Default)&lt;/font&gt;" style="text;html=1;align=center;fontSize=14;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="400" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="col1-cmd" value="&lt;font face=&quot;Consolas&quot;&gt;Set-VMNetworkAdapterVlan&lt;br&gt;  -VMName 'myVM'&lt;br&gt;  -Untagged&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#cccccc;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="140" width="320" height="60" as="geometry"/>
        </mxCell>
        <!-- VM -->
        <mxCell id="col1-vm" value="&lt;b&gt;VM&lt;/b&gt;&lt;br&gt;eth0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="160" y="230" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="col1-frame1" value="Dst | Src | &lt;b&gt;No Tag&lt;/b&gt; | Payload" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#999999;fontSize=10;fontFamily=Consolas;" vertex="1" parent="1">
          <mxGeometry x="120" y="290" width="280" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="col1-arrow1" value="" style="endArrow=block;endFill=1;strokeColor=#d6b656;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="260" y="325" as="sourcePoint"/>
            <mxPoint x="260" y="360" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <!-- vSwitch -->
        <mxCell id="col1-vs" value="&lt;b&gt;vSwitch&lt;/b&gt;&lt;br&gt;Passes as-is" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="160" y="360" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="col1-frame2" value="Dst | Src | &lt;b&gt;No Tag&lt;/b&gt; | Payload" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#999999;fontSize=10;fontFamily=Consolas;" vertex="1" parent="1">
          <mxGeometry x="120" y="420" width="280" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="col1-arrow2" value="" style="endArrow=block;endFill=1;strokeColor=#9673a6;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="260" y="455" as="sourcePoint"/>
            <mxPoint x="260" y="490" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <!-- Physical NIC / Wire -->
        <mxCell id="col1-wire" value="&lt;b&gt;On the Wire&lt;/b&gt;&lt;br&gt;Untagged → Switch assigns Native VLAN" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="120" y="490" width="280" height="50" as="geometry"/>
        </mxCell>

        <!-- ===== COLUMN 2: ACCESS ===== -->
        <mxCell id="col2-header" value="&lt;b&gt;Mode 2: Access&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#009900&quot;&gt;✅ Recommended for Azure Local&lt;/font&gt;" style="text;html=1;align=center;fontSize=14;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="560" y="80" width="400" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="col2-cmd" value="&lt;font face=&quot;Consolas&quot;&gt;Set-VMNetworkAdapterVlan&lt;br&gt;  -VMName 'myVM'&lt;br&gt;  -Access -VlanId 4&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#cccccc;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="600" y="140" width="320" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="col2-vm" value="&lt;b&gt;VM&lt;/b&gt;&lt;br&gt;eth0 (no VLAN awareness)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="660" y="230" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="col2-frame1" value="Dst | Src | &lt;b&gt;No Tag&lt;/b&gt; | Payload" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#999999;fontSize=10;fontFamily=Consolas;" vertex="1" parent="1">
          <mxGeometry x="620" y="290" width="280" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="col2-arrow1" value="" style="endArrow=block;endFill=1;strokeColor=#d6b656;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="760" y="325" as="sourcePoint"/>
            <mxPoint x="760" y="360" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="col2-vs" value="&lt;b&gt;vSwitch&lt;/b&gt;&lt;br&gt;Adds VLAN 4 tag" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="660" y="360" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="col2-frame2" value="Dst | Src | &lt;b&gt;802.1Q VLAN 4&lt;/b&gt; | Payload" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontFamily=Consolas;" vertex="1" parent="1">
          <mxGeometry x="620" y="420" width="280" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="col2-arrow2" value="" style="endArrow=block;endFill=1;strokeColor=#82b366;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="760" y="455" as="sourcePoint"/>
            <mxPoint x="760" y="490" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="col2-wire" value="&lt;b&gt;On the Wire&lt;/b&gt;&lt;br&gt;Tagged VLAN 4 → ToR trunk accepts it" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="620" y="490" width="280" height="50" as="geometry"/>
        </mxCell>

        <!-- ===== COLUMN 3: TRUNK ===== -->
        <mxCell id="col3-header" value="&lt;b&gt;Mode 3: Trunk&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#cc0000&quot;&gt;⚠️ Breaks on Azure Local&lt;/font&gt;" style="text;html=1;align=center;fontSize=14;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="1060" y="80" width="400" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="col3-cmd" value="&lt;font face=&quot;Consolas&quot;&gt;Set-VMNetworkAdapterVlan&lt;br&gt;  -VMName 'myVM' -Trunk&lt;br&gt;  -NativeVlanId 1&lt;br&gt;  -AllowedVlanIdList '4'&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#cccccc;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1100" y="140" width="320" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="col3-vm" value="&lt;b&gt;VM&lt;/b&gt;&lt;br&gt;eth0.4 (VLAN sub-interface)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1160" y="230" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="col3-frame1" value="Dst | Src | &lt;b&gt;802.1Q VLAN 4&lt;/b&gt; | Payload" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontFamily=Consolas;" vertex="1" parent="1">
          <mxGeometry x="1120" y="290" width="280" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="col3-arrow1" value="" style="endArrow=block;endFill=1;strokeColor=#d6b656;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1260" y="325" as="sourcePoint"/>
            <mxPoint x="1260" y="360" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="col3-vs" value="&lt;b&gt;vSwitch&lt;/b&gt;&lt;br&gt;Passes through (in theory)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1160" y="360" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="col3-frame2" value="Dst | Src | &lt;b&gt;802.1Q VLAN 4&lt;/b&gt; | Payload" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontFamily=Consolas;" vertex="1" parent="1">
          <mxGeometry x="1120" y="420" width="280" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="col3-arrow2" value="" style="endArrow=block;endFill=1;strokeColor=#b85450;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1260" y="455" as="sourcePoint"/>
            <mxPoint x="1260" y="490" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="col3-wire" value="&lt;b&gt;On the Wire&lt;/b&gt;&lt;br&gt;Tagged VLAN 4 — but return path fails" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1120" y="490" width="280" height="50" as="geometry"/>
        </mxCell>

        <!-- Divider lines -->
        <mxCell id="div1" value="" style="endArrow=none;dashed=1;strokeColor=#cccccc;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="520" y="80" as="sourcePoint"/>
            <mxPoint x="520" y="570" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="div2" value="" style="endArrow=none;dashed=1;strokeColor=#cccccc;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1020" y="80" as="sourcePoint"/>
            <mxPoint x="1020" y="570" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Bottom summary -->
        <mxCell id="summary" value="&lt;b&gt;Key Insight:&lt;/b&gt; In all three modes, the physical switch port stays in &lt;b&gt;trunk mode&lt;/b&gt;. The difference is &lt;i&gt;who adds the VLAN tag&lt;/i&gt; — the vSwitch (Access) or the VM itself (Trunk)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="200" y="580" width="1100" height="50" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
